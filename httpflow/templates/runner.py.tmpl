# ─── main ───────────────────────────────────────────────────────────
def main():
    p = argparse.ArgumentParser(description="Generated API workflow runner")
    p.add_argument("-v", "--var", action="append", default=[], metavar="K=V",
                   help="override DEFAULT_VARS entries (key=value)")
    p.add_argument("-q", "--quiet", action="store_true",
                   help="suppress per-step request/response detail (detail is ON by default)")
    p.add_argument("--pretty-json", action="store_true",
                   help="pretty-print JSON request/response bodies with 2-space indent")
    p.add_argument("--no-mask", action="store_true",
                   help="disable masking of sensitive fields in log output (masking is ON by default)")
    p.add_argument("--repeat-vars", action="append", default=[], metavar="K=V1,V2,...",
                   help="comma-separated values for ${repeat.K} (repeatable). "
                        "All --repeat-vars must share the same number of values; "
                        "the workflow is executed once per index.")
    args = p.parse_args()

    store = {"vars": dict(DEFAULT_VARS), "steps": {}, "repeat": {}}
    for kv in args.var:
        if "=" not in kv:
            print(f"error: -v/--var requires key=value, got: {kv!r}", file=sys.stderr)
            return 1
        k, _, v = kv.partition("=")
        store["vars"][k.strip()] = v

    iterations = _build_repeat_iterations(args.repeat_vars)
    total = len(iterations)

    for _idx, _repeat_iter in enumerate(iterations, start=1):
        store["repeat"] = dict(_repeat_iter)
        if _repeat_iter:
            store["steps"] = {}
            print(f"=== repeat iteration {_idx}/{total} {_repeat_iter} ===")

        # === Workflow ===
        # Comment out a line to skip that step. Reorder lines to change execution order.
{{STEP_CALLS}}

    return 0


if __name__ == "__main__":
    sys.exit(main())
