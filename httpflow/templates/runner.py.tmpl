    else:
        body_bytes = None

    print(f"==> {_now()} [{name}] {method} {_mask_url(url, disabled=no_mask)}")
    if description:
        for line in description.splitlines() or [""]:
            print(f"    # {line}")
    if not quiet:
        _log_request(method, url, headers, body_bytes, body_form, pretty_json, no_mask=no_mask)

    status, reason, resp_headers, text, body_json = do_request(method, url, headers, body_bytes)
    print(f"<== {_now()} [{name}] status={status}")
    if not quiet:
        _log_response(status, reason, resp_headers, text, pretty_json, no_mask=no_mask)

    captured = {}
    if capture:
        if body_json is None:
            raise RuntimeError(f"step {name!r}: capture requested but response is not JSON")
        for var, path in capture.items():
            captured[var] = extract(body_json, path)
            store["vars"][var] = captured[var]
            if not quiet:
                shown = _mask_value(var, captured[var], disabled=no_mask)
                print(f"    * capture {var} = {shown!r}")
    store["steps"][name] = captured


