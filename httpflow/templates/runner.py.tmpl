        lines.extend(f"    - {k}={v}" for k, v in DEFAULT_VARS.items())
    else:
        lines.append("    - none")
    if REQUIRED_VARS:
        lines.append("  * Required parameters (referenced by ${var.*} but not embedded)")
        lines.extend(f"    - {k}" for k in REQUIRED_VARS)
    return "\n".join(lines)


