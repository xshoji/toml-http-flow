def run_step(store, name, method, url, *,
             headers=None, body=None, body_form=None, capture=None,
             description=None, quiet=False, pretty_json=False, no_mask=False):
    """Render → send → log → capture a single HTTP step."""
    url = render(url, store)
    headers = render_mapping(headers, store) if headers else {}
    if body is not None:
        body_bytes = render(body, store).encode("utf-8")
    elif body_form is not None:
        body_form = render_mapping(body_form, store)
        body_bytes = urllib.parse.urlencode(body_form).encode("utf-8")
        if not any(h.lower() == "content-type" for h in headers):
