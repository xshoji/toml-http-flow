# Env var:
#   HTTPFLOW_MASK_EXTRA - comma-separated key names added to the default set.
#   Applies to headers, body, query, and capture alike.
_PLACEHOLDER = "***"
DEFAULT_SENSITIVE_HEADERS = frozenset({
    "authorization", "proxy-authorization", "cookie", "set-cookie",
    "x-api-key", "x-auth-token", "x-access-token",
    "x-csrf-token", "x-xsrf-token",
    "x-session-token", "x-session-id", "x-secret-key",
