def _mask_norm(name):
    return name.lower().replace("_", "").replace("-", "").replace(" ", "")


def _mask_targets():
    base = set(_MASK_DEFAULTS)
    raw = os.environ.get("HTTPFLOW_MASK_EXTRA", "")
    base |= {_mask_norm(item) for item in raw.split(",") if item.strip()}
    return base


def _mask_obj(obj, targets):
