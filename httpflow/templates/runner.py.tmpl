DEFAULT_SENSITIVE_BODY_KEYS = frozenset({
    "password", "passwd", "pwd",
    "secret", "client_secret",
    "token", "access_token", "refresh_token", "id_token",
    "auth_token", "session_token",
    "api_key", "apikey", "private_key",
    "authorization", "auth", "session", "session_id", "cookie",
    "credit_card", "card_number", "cvv", "cvc", "pin", "ssn",
})


def _mask_norm(name):
    return name.lower().replace("_", "").replace("-", "").replace(" ", "")


def _mask_extra_set():
    raw = os.environ.get("HTTPFLOW_MASK_EXTRA", "")
    return {_mask_norm(item) for item in raw.split(",") if item.strip()}


def _mask_all_targets():
    base = {_mask_norm(x) for x in DEFAULT_SENSITIVE_HEADERS}
    base |= {_mask_norm(x) for x in DEFAULT_SENSITIVE_BODY_KEYS}
    base |= _mask_extra_set()
    return base


def mask_headers(headers, disabled=False):
    if disabled:
        return dict(headers)
    targets = _mask_all_targets()
    return {k: (_PLACEHOLDER if _mask_norm(k) in targets else v) for k, v in headers.items()}


def _mask_obj(obj, targets):
    if isinstance(obj, dict):
        return {
            k: (_PLACEHOLDER if isinstance(k, str) and _mask_norm(k) in targets
                else _mask_obj(v, targets))
            for k, v in obj.items()
        }
    if isinstance(obj, list):
        return [_mask_obj(item, targets) for item in obj]
    return obj


def mask_form(form, disabled=False):
    if disabled:
        return dict(form)
    targets = _mask_all_targets()
    return {k: (_PLACEHOLDER if _mask_norm(k) in targets else v) for k, v in form.items()}


def mask_url(url, disabled=False):
