        return

    parsed = urllib.parse.urlparse(url)
    path = parsed.path or "/"
    if parsed.query:
        path = f"{path}?{parsed.query}"
    print(f"    > {method} {path} HTTP/1.1")
    print(f"    > Host: {parsed.netloc}")

    # Explicit user headers
    for k, v in headers.items():
        print(f"    > {k}: {v}")

    # Estimated headers
    if body_bytes is not None:
        print(f"    > Content-Length: {len(body_bytes)}")
    lower_headers = {h.lower() for h in headers}
    if "user-agent" not in lower_headers:
        print(
            f"    > User-Agent: Python-urllib/{sys.version_info.major}.{sys.version_info.minor}"
        )
    if "accept-encoding" not in lower_headers:
        print("    > Accept-Encoding: identity")

    if body_form is not None:
        print("    > (form)")
        for k, v in body_form.items():
            print(f"    >   {k} = {v}")
    elif body_bytes is not None:
        try:
            text = body_bytes.decode("utf-8")
        except UnicodeDecodeError:
            print(f"    > <{len(body_bytes)} bytes>")
            return
        print("    >")
        for line in text.splitlines() or [""]:
            print(f"    > {line}")


