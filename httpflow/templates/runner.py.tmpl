_MASK_PLACEHOLDER = "***"
_MASK_DEFAULTS = frozenset({
    "authorization", "proxyauthorization", "cookie", "setcookie",
    "xapikey", "xauthtoken", "xaccesstoken",
    "xcsrftoken", "xxsrftoken",
