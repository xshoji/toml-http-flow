def _now():
    """Local time stamp with ms precision, e.g. '2026-05-19 23:35:49.123'."""
    now = datetime.datetime.now()
    return now.strftime("%Y-%m-%d %H:%M:%S.") + f"{now.microsecond // 1000:03d}"


def render(text, store):
    """Expand ${path.to.value} references in text using store. $$ → literal $."""
    def repl(m):
        if m.group(0) == "$$":
            return "$"
        if "." not in m.group(1) and m.group(1) in store.get("vars", {}):
            return str(store["vars"][m.group(1)])
