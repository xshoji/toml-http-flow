{{REPEAT_HELPERS}}

# ─── defaults ───────────────────────────────────────────────────────
REQUIRED_VARS="{{REQUIRED_VARS}}"
REQUIRED_REPEAT_VARS="{{REQUIRED_REPEAT_VARS}}"

# ─── validate required vars ─────────────────────────────────────────
__hf_validate_vars() {
    local missing="" v
    for v in $REQUIRED_VARS; do
        __hf_var_exists "$v" || missing="$missing $v"
    done
    if [ -n "$missing" ]; then
        printf '%s\n' "error: missing required -v/--var for: [$missing ]" >&2
        return 1
    fi
}

# ─── validate required repeat vars ──────────────────────────────────
__hf_validate_repeat_vars() {
    local missing="" v
    for v in $REQUIRED_REPEAT_VARS; do
        # check user-provided repeat vars
        local found=0 kv k
        for kv in ${user_repeat_vars[@]+"${user_repeat_vars[@]}"}; do
            k="${kv%%=*}"
            [ "$k" = "$v" ] && { found=1; break; }
        done
        # also check defaults embedded in script (DEFAULT_REPEAT_VARS / __HF_RDEF_*)
        if [ "$found" -eq 0 ]; then
            local enc defname
            enc="$(__hf_enc "${v}-rdef")"
            defname="__HF_RDEF_${enc}"
            [ -n "${!defname+x}" ] && found=1
        fi
        [ "$found" -eq 0 ] && missing="$missing $v"
    done
    if [ -n "$missing" ]; then
        printf '%s\n' "error: --repeat-vars missing for: [$missing ]" >&2
        return 1
    fi
}

# ─── step functions ─────────────────────────────────────────────────
{{STEP_FUNCTIONS}}

# ─── main ───────────────────────────────────────────────────────────
main() {
    local quiet=0 pretty_json=0 no_mask=0
    local -a user_vars=()
    local -a user_repeat_vars=()

    while (( $# > 0 )); do
        case "$1" in
            -v|--var) shift; user_vars+=("$1"); shift ;;
            -q|--quiet) quiet=1; shift ;;
            --pretty-json) pretty_json=1; shift ;;
            --no-mask) no_mask=1; shift ;;
            --repeat-vars) shift; user_repeat_vars+=("$1"); shift ;;
            -h|--help)
                cat <<'EOF'
Generated API workflow runner

Options:
  -v, --var K=V          set runtime variable (repeatable)
  -q, --quiet            suppress per-step request/response detail
  --pretty-json          pretty-print JSON bodies with jq
  --no-mask              disable masking of sensitive fields
  --repeat-vars K=V1,V2  comma-separated values for ${repeat.K} (repeatable)
  -h, --help             show this help
EOF
                return 0
                ;;
            *) printf '%s\n' "error: unknown argument: $1" >&2; return 1 ;;
        esac
    done

    # defaults
{{APPLY_DEFAULT_VARS}}

    # user vars (last-wins)
    local kv k v
    for kv in ${user_vars[@]+"${user_vars[@]}"}; do
        if [[ "$kv" != *=* ]]; then
            printf '%s\n' "error: -v/--var requires key=value, got: $kv" >&2
            return 1
        fi
        k="${kv%%=*}"; v="${kv#*=}"
        __hf_var_set "$k" "$v"
    done

    __hf_validate_vars || return 1

    __hf_validate_repeat_vars || return 1

    __hf_tmpdir="$(mktemp -d)"
    trap 'rm -rf "$__hf_tmpdir"' EXIT

    # repeat setup
{{MAIN_REPEAT_SETUP}}
        # workflow steps
{{STEP_CALLS}}
{{MAIN_REPEAT_DONE}}

    return 0
}

main "$@"
