# Generated by toml-http-flow {{VERSION}} at {{GENERATED_AT}}
set -uo pipefail

# ─── bash version guard ─────────────────────────────────────────────
if (( BASH_VERSINFO[0] < 3 || (BASH_VERSINFO[0] == 3 && BASH_VERSINFO[1] < 2) )); then
    printf '%s\n' "error: bash 3.2+ is required (found ${BASH_VERSION})" >&2
    exit 1
fi

# ─── dependency preflight ───────────────────────────────────────────
__hf_missing=""
command -v curl >/dev/null 2>&1 || __hf_missing="$__hf_missing curl"
command -v jq  >/dev/null 2>&1 || __hf_missing="$__hf_missing jq"
{{UUID_DEP_CHECK}}
if [ -n "$__hf_missing" ]; then
    printf '%s\n' "error: missing dependencies:$__hf_missing" >&2
    exit 1
fi

# ─── timestamp helper (auto-detect %N support) ──────────────────────
__hf_date_has_ns=0
if date '+%N' 2>/dev/null | grep -qE '^[0-9]{9}$'; then __hf_date_has_ns=1; fi
__hf_ts() {
    if [ "$__hf_date_has_ns" -eq 1 ]; then
        date '+%F %T.%3N'
    else
        printf '%s.000\n' "$(date '+%F %T')"
    fi
}

# ─── key encoding ───────────────────────────────────────────────────
__hf_enc() {
    local s="$1" out="" i c o
    for (( i = 0; i < ${#s}; i++ )); do
        c="${s:$i:1}"
        if [[ "$c" =~ [A-Za-z0-9] ]]; then
            out="${out}${c}"
        else
            printf -v o '%02x' "'$c"
            out="${out}_${o}_"
        fi
    done
    printf '%s' "$out"
}

# ─── variable store (bash 3.2: dynamic variables + indirect ref) ────
__hf_var_set() {
    local enc
    enc="$(__hf_enc "${1}-set")"
    printf -v "__HF_VAR_${enc}" '%s' "$2"
}
__hf_var_get() {
    local enc name
    enc="$(__hf_enc "${1}-set")"
    name="__HF_VAR_${enc}"
    printf '%s' "${!name}"
}
__hf_var_exists() {
    local enc name
    enc="$(__hf_enc "${1}-set")"
    name="__HF_VAR_${enc}"
    [ -n "${!name+x}" ]
}

# ─── repeat store ───────────────────────────────────────────────────
__hf_rep_set() {
    local enc
    enc="$(__hf_enc "${1}-rep")"
    printf -v "__HF_REP_${enc}" '%s' "$2"
}
__hf_rep_get() {
    local enc name
    enc="$(__hf_enc "${1}-rep")"
    name="__HF_REP_${enc}"
    printf '%s' "${!name}"
}

# ─── template render (eval-free, non-recursive, bash 3.2) ───────────
__hf_render() {
    local out_var="$1" text="$2" result="" i=0 ch nxt key val name
    while (( i < ${#text} )); do
        ch="${text:$i:1}"
        if [ "$ch" = '$' ]; then
            nxt="${text:$((i+1)):1}"
            if [ "$nxt" = '$' ]; then
                result="${result}$"
                i=$((i+2)); continue
            elif [ "$nxt" = '{' ]; then
                local j
                j=$((i+2))
                while (( j < ${#text} )) && [ "${text:$j:1}" != '}' ]; do
                    j=$((j+1))
                done
                if (( j >= ${#text} )); then
                    printf '%s\n' "error: unclosed \${...} in template" >&2
                    return 1
                fi
                key="${text:$((i+2)):$((j-i-2))}"
                val=""
                case "$key" in
                    random.UUID)
                        val="$(uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid 2>/dev/null)"
                        val="$(printf '%s' "$val" | tr '[:upper:]' '[:lower:]')"
                        ;;
                    random.UUID_HEX)
                        val="$(uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid 2>/dev/null)"
                        val="$(printf '%s' "$val" | tr '[:upper:]' '[:lower:]' | tr -d '-')"
                        ;;
                    env.*)
                        name="${key#env.}"; val="${!name:-}"
                        ;;
                    var.*)
                        name="${key#var.}"; val="$(__hf_var_get "$name")"
                        ;;
                    repeat.*)
                        name="${key#repeat.}"; val="$(__hf_rep_get "$name")"
                        ;;
                    *)
                        if __hf_var_exists "$key"; then
                            val="$(__hf_var_get "$key")"
                        else
                            local first rest tmp jq_path segment
                            first="${key%%.*}"
                            rest="${key#*.}"
                            if __hf_var_exists "$first"; then
                                tmp="$(__hf_var_get "$first")"
                                jq_path=""
                                while [ -n "$rest" ]; do
                                    segment="${rest%%.*}"
                                    if [[ "$segment" =~ ^\[([0-9]+)\]$ ]]; then
                                        jq_path="${jq_path}[${BASH_REMATCH[1]}]"
                                    else
                                        jq_path="${jq_path}.\"${segment}\""
                                    fi
                                    [ "$rest" = "$segment" ] && break
                                    rest="${rest#*.}"
                                done
                                val="$(printf '%s' "$tmp" | jq -r -e "${jq_path}" 2>/dev/null)"
                            fi
                        fi
                        ;;
                esac
                result="${result}${val}"
                i=$((j+1)); continue
            fi
        fi
        result="${result}${ch}"
        i=$((i+1))
    done
    printf -v "$out_var" '%s' "$result"
}

# ─── mask helpers ───────────────────────────────────────────────────
# Normalise keyword: lowercase, strip _ - space
__hf_mnorm() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -d '_- '
}

# Default sensitive keywords (already normalised)
__HF_MASK_KWS="authorization
proxyauthorization
cookie
setcookie
xapikey
xauthtoken
xaccesstoken
xcsrftoken
xxsrftoken
xsessiontoken
xsessionid
xsecretkey
password
passwd
pwd
secret
clientsecret
token
accesstoken
refreshtoken
idtoken
authtoken
sessiontoken
apikey
privatekey
auth
session
sessionid
creditcard
cardnumber
cvv
cvc
pin
ssn
"

# Best-effort mask for a JSON string (requires jq).
__hf_mask_json() {
    local text no_mask kw expr out ec
    text="$1"; no_mask="$2"
    [ "$no_mask" = "1" ] && { printf '%s' "$text"; return; }

    expr=""
    local inner=""
    while IFS= read -r kw; do
        [ -n "$kw" ] || continue
        if [ -n "$inner" ]; then inner="${inner} or "; fi
        inner="${inner}((.key | ascii_downcase | gsub(\"[_-]\";\"\")) == \"${kw}\")"
    done <<< "$__HF_MASK_KWS"

    if [ -n "${HTTPFLOW_MASK_EXTRA:-}" ]; then
        local old_ifs="$IFS"; IFS=','
        for extra in ${HTTPFLOW_MASK_EXTRA:-}; do
            extra="${extra# }"; extra="${extra% }"
            [ -n "$extra" ] || continue
            extra="$(__hf_mnorm "$extra")"
            if [ -n "$inner" ]; then inner="${inner} or "; fi
            inner="${inner}((.key | ascii_downcase | gsub(\"[_-]\";\"\")) == \"${extra}\")"
        done
        IFS="$old_ifs"
    fi

    if [ -n "$inner" ]; then
        expr="walk(if type == \"object\" then with_entries(if ${inner} then .value = \"***\" else . end) else . end)"
    fi

    if [ -n "$expr" ]; then
        out="$(printf '%s' "$text" | jq -c "$expr" 2>/dev/null)"
        ec=$?
        if [ "$ec" -eq 0 ] && [ -n "$out" ]; then
            printf '%s' "$out"
        else
            printf '%s' "$text"
        fi
    else
        printf '%s' "$text"
    fi
}

# Apply mask to a single line using simple sed replacements.
# If the key-part of the line matches a sensitive keyword, mask the value.
__hf_mask_line() {
    local line no_mask keypart norm kw extra matched
    line="$1"; no_mask="$2"
    [ "$no_mask" = "1" ] && { printf '%s\n' "$line"; return; }

    keypart=""
    if [[ "$line" =~ ^([^:]+):[[:space:]] ]]; then
        keypart="${BASH_REMATCH[1]}"
        keypart="${keypart#>}"; keypart="${keypart#<}"; keypart="${keypart# }"
    elif [[ "$line" =~ \"([^\"]+)\"[[:space:]]*: ]]; then
        keypart="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^([^=]+)= ]]; then
        keypart="${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^\*[[:space:]]+capture[[:space:]]+([^=]+)= ]]; then
        keypart="${BASH_REMATCH[1]}"
        keypart="${keypart// /}"
    fi

    [ -z "$keypart" ] && { printf '%s\n' "$line"; return; }

    norm="$(__hf_mnorm "$keypart")"
    matched=0
    while IFS= read -r kw; do
        [ -n "$kw" ] || continue
        [ "$norm" = "$kw" ] && { matched=1; break; }
    done <<< "$__HF_MASK_KWS"

    if [ "$matched" -eq 0 ] && [ -n "${HTTPFLOW_MASK_EXTRA:-}" ]; then
        local old_ifs="$IFS"; IFS=','
        for extra in ${HTTPFLOW_MASK_EXTRA:-}; do
            extra="${extra# }"; extra="${extra% }"
            [ -n "$extra" ] || continue
            extra="$(__hf_mnorm "$extra")"
            [ "$norm" = "$extra" ] && { matched=1; break; }
        done
        IFS="$old_ifs"
    fi

    if [ "$matched" -eq 1 ]; then
        # Mask everything after the last : or = separator (and its optional spaces)
        printf '%s\n' "$line" | sed -e 's/\([:=][[:space:]]*\).*/\1***/'
    else
        printf '%s\n' "$line"
    fi
}

# ─── pretty-json via jq ─────────────────────────────────────────────
__hf_pretty() {
    local text enabled out
    text="$1"; enabled="$2"
    if [ "$enabled" != "1" ] || [ -z "$text" ]; then
        printf '%s' "$text"; return
    fi
    out=""
    out="$(printf '%s' "$text" | jq . 2>/dev/null)"
    if [ $? -eq 0 ]; then printf '%s' "$out"; else printf '%s' "$text"; fi
}

# ─── capture header helper ──────────────────────────────────────────
__hf_get_header() {
    local raw target line key value
    raw="$1"
    target="$(printf '%s' "$2" | tr '[:upper:]' '[:lower:]')"
    while IFS= read -r line; do
        [[ "$line" =~ ^HTTP/ ]] && continue
        [ -z "$line" ] && continue
        key="${line%%:*}"; value="${line#*: }"
        [ "$(printf '%s' "$key" | tr '[:upper:]' '[:lower:]')" = "$target" ] && { printf '%s' "$value"; return 0; }
    done <<< "$raw"
    return 1
}

